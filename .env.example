# --- Figma ---
# Token d'accès personnel Figma.
# Le créer ici : https://www.figma.com/developers/api#access-tokens
# (Compte Figma > Settings > Security > Personal access tokens > Generate new token,
#  cocher au minimum le scope "File content" en lecture).
FIGMA_TOKEN=

# Clé du fichier Figma. Visible dans l'URL du fichier :
# https://www.figma.com/design/<FIGMA_FILE_KEY>/Nom-du-fichier?node-id=...
FIGMA_FILE_KEY=

# (Optionnel) node-id par défaut à exporter, ex. "123:456".
# Laisser vide pour traiter toutes les pages.
FIGMA_NODE_ID=

# --- TinaCMS ---
# En local, laisser vide : l'édition se fait directement sur les fichiers (npm run dev:cms).
# Pour activer l'admin en ligne (Tina Cloud), créer un projet sur https://app.tina.io
# puis renseigner :
PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
# Branche Git éditée par Tina Cloud (ex. main).
TINA_BRANCH=main

# --- Analytics (Matomo, mode sans cookie) ---
# URL de votre instance Matomo, avec le / final (auto-hébergée ou cloud).
PUBLIC_MATOMO_URL=
# Identifiant du site dans Matomo (Administration > Sites web).
PUBLIC_MATOMO_SITE_ID=
