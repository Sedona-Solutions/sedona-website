---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import DownloadButton from "../components/DownloadButton.astro";

const entry = await getEntry("page", "politique-rse");
const { Content } = await render(entry);
const p = entry.data;
---

<BaseLayout title={`${p.titre} — Sedona`} description={p.intro}>
  <PageHeader eyebrow={p.eyebrow} titre={p.titre} intro={p.intro} />
  <section class="container page-body">
    {p.dateMaj && <p class="page-body__maj">Dernière mise à jour : {p.dateMaj}</p>}
    <DownloadButton href={p.fichier} label={p.fichierLabel} />
    <div class="prose"><Content /></div>
  </section>
</BaseLayout>

<style>
  .page-body { padding-block: clamp(2rem, 5vw, 3.5rem) clamp(3rem, 7vw, 6rem); max-width: 760px; }
  .page-body__maj {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
</style>
