---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import home from "../../../content/home/index.json";
import CtaFinal from "../../components/home/CtaFinal.astro";

const projets = (await getCollection("projet"))
  .map((p) => ({ ...p.data, slug: p.id }))
  .sort((a, b) => +new Date(b.date ?? 0) - +new Date(a.date ?? 0));

// Catégorie d'un projet = son premier tag, normalisé en slug.
const slug = (s = "") =>
  s.normalize("NFD").replace(/[̀-ͯ]/g, "").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");

// Filtres Figma → catégorie ciblée (le compteur = nb de réalisations).
const filtres = [
  { label: "Toutes nos réalisations", cat: "all" },
  { label: "BTP", cat: "btp" },
  { label: "Banque", cat: "banque" },
  { label: "Media", cat: "media" },
  { label: "Industrie & Défense", cat: "industrie" },
  { label: "Luxe", cat: "luxe" },
  { label: "Services publiques", cat: "service-publique" },
  { label: "Santé", cat: "sante" },
  { label: "Services", cat: "services" },
];
const compte = (cat) => (cat === "all" ? projets.length : projets.filter((p) => slug(p.tags?.[0] ?? "") === cat).length);
const clients = home.clientsSection?.logos ?? [];
---

<BaseLayout title="Projets — Sedona" description="Nos réalisations et études de cas client.">
  <section class="phead">
    <div class="container">
      <h1 class="phead__title">
        Retour sur<br />nos plus beaux <mark class="hl hl--cactus">projets</mark>
        <img class="phead__squiggle" src="/deco/projets-squiggle.svg" alt="" aria-hidden="true" />
      </h1>
      <p class="phead__sub">Des projets qualitatifs issus du fruit d'une collaboration étroite entre les membres de notre tribu et nos clients.</p>
    </div>
  </section>

  <nav class="filtres" aria-label="Filtrer les projets">
    <ul class="container filtres__list">
      {filtres.map((fl, i) => (
        <li>
          <button class={`filtre ${i === 0 ? "is-active" : ""}`} type="button" data-cat={fl.cat}>
            {fl.label}<sup>{compte(fl.cat)}</sup>
          </button>
        </li>
      ))}
    </ul>
  </nav>

  <section class="pgrid">
    <ul class="container pgrid__list">
      {
        projets.map((p) => (
          <li class="pcard" data-cat={slug(p.tags?.[0] ?? "")}>
            <a href={`/projets/${p.slug}`} class="pcard__media">
              {p.couverture ? <img src={p.couverture} alt={p.titre} loading="lazy" /> : <span class="pcard__ph" aria-hidden="true" />}
            </a>
            <h2 class="pcard__title">{p.client ?? p.titre}</h2>
            {p.tags?.length > 0 && <ul class="pcard__tags">{p.tags.map((tg) => <li>{tg}</li>)}</ul>}
          </li>
        ))
      }
    </ul>
    <p class="pgrid__empty container" hidden>Aucune réalisation dans cette catégorie pour le moment.</p>

    <div class="pagination container">
      <p class="pagination__more">HOP HOP HOP, LA SUITE !</p>
      <div class="pager">
        <button class="pager__arrow" type="button" data-dir="prev" aria-label="Page précédente">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <ol class="pager__nums"></ol>
        <button class="pager__arrow" type="button" data-dir="next" aria-label="Page suivante">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <img class="pager__squiggle" src="/deco/pagination-arrow.svg" alt="" aria-hidden="true" />
      </div>
    </div>
  </section>

  <section class="autres">
    <div class="container">
      <h2 class="autres__title">Ces <mark class="hl hl--sunshine">clients</mark> ont aussi tenté l'aventure avec nous</h2>
      <img class="autres__logos" src="/uploads/clients/clients-logos.png" alt="Logos de nos clients" loading="lazy" />
    </div>
  </section>

  <CtaFinal cta={home.ctaFinal} />
</BaseLayout>

<script>
  const TAILLE = 6; // projets par page
  const boutons = document.querySelectorAll<HTMLButtonElement>(".filtre");
  const cartes = Array.from(document.querySelectorAll<HTMLElement>(".pcard"));
  const vide = document.querySelector<HTMLElement>(".pgrid__empty");
  const numsEl = document.querySelector<HTMLElement>(".pager__nums");
  const pagination = document.querySelector<HTMLElement>(".pagination");
  const grille = document.querySelector<HTMLElement>(".pgrid");
  const fleches = document.querySelectorAll<HTMLButtonElement>(".pager__arrow");
  let cat = "all";
  let page = 1;

  const filtrees = () => cartes.filter((c) => cat === "all" || c.dataset.cat === cat);

  function rendre(scroll = false) {
    const liste = filtrees();
    const pages = Math.max(1, Math.ceil(liste.length / TAILLE));
    if (page > pages) page = 1;
    cartes.forEach((c) => (c.style.display = "none"));
    liste.slice((page - 1) * TAILLE, page * TAILLE).forEach((c) => (c.style.display = ""));
    if (vide) vide.hidden = liste.length > 0;

    if (numsEl) {
      numsEl.innerHTML = "";
      for (let i = 1; i <= pages; i++) {
        const li = document.createElement("li");
        const b = document.createElement("button");
        b.type = "button";
        b.textContent = String(i);
        if (i === page) b.classList.add("is-active");
        b.addEventListener("click", () => { page = i; rendre(true); });
        li.appendChild(b);
        numsEl.appendChild(li);
      }
    }
    fleches.forEach((f) => ((f as HTMLButtonElement).disabled = f.dataset.dir === "prev" ? page <= 1 : page >= pages));
    if (pagination) pagination.style.display = liste.length === 0 || pages <= 1 ? "none" : "";
    if (scroll && grille) grille.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  boutons.forEach((btn) => {
    btn.addEventListener("click", () => {
      boutons.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      cat = btn.dataset.cat ?? "all";
      page = 1;
      rendre();
    });
  });
  fleches.forEach((f) => f.addEventListener("click", () => {
    const pages = Math.max(1, Math.ceil(filtrees().length / TAILLE));
    page = f.dataset.dir === "prev" ? Math.max(1, page - 1) : Math.min(pages, page + 1);
    rendre(true);
  }));

  rendre();
</script>

<style>
  .phead { background: var(--color-canyon-50); padding-block: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 3vw, 2.5rem); text-align: center; }
  .phead__title {
    position: relative; display: inline-block; margin: 0; font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1.05; letter-spacing: -0.03em; color: #3b0800;
  }
  .phead__title .hl { line-height: 1.2; }
  .phead__squiggle { position: absolute; top: -0.4rem; right: 1.2rem; width: clamp(64px, 6vw, 100px); height: auto; z-index: 1; }
  .phead__sub { margin: 1.5rem auto 0; max-width: 56ch; font-family: var(--font-sans); font-weight: 500; font-size: clamp(1.1rem, 1.6vw, 1.5rem); line-height: 1.3; color: #3b0800; }

  /* Filtres : libellés Space Grotesk séparés par « / », compteur en exposant,
     actif souligné d'un trait rouge crayonné (SVG Figma). */
  .filtres { background: var(--color-canyon-50); }
  .filtres__list { list-style: none; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.25rem 0; padding-block: 1rem 2.5rem; margin-block: 0; }
  .filtres__list li:not(:last-child) .filtre::after { content: "/"; margin: 0 0.5rem 0 0.65rem; font-weight: 400; color: var(--color-text-muted); }
  .filtre { font-family: var(--font-sans); font-weight: 600; font-size: clamp(1.125rem, 1.6vw, 1.5rem); color: #3b0800; background: none; border: none; padding: 0; cursor: pointer; }
  .filtre sup { font-size: 0.5em; font-weight: 500; margin-left: 0.15em; vertical-align: super; }
  .filtre.is-active { background: url("/deco/filtre-underline.svg") no-repeat left bottom / 100% 0.5rem; padding-bottom: 0.7rem; }

  .pgrid { background: var(--color-canyon-50); padding-block: clamp(1rem, 2vw, 1.5rem) clamp(3rem, 6vw, 5rem); }
  .pgrid__list { list-style: none; padding-block: 0; margin-block: 0; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2.5rem, 4vw, 3.5rem) 2rem; }
  .pcard__media { display: block; aspect-ratio: 640 / 571; border-radius: 20px; overflow: hidden; background: var(--color-neutral-100); }
  .pcard__media img { width: 100%; height: 100%; object-fit: cover; }
  .pcard__ph { display: block; width: 100%; height: 100%; background: linear-gradient(135deg, var(--color-canyon-200), var(--color-red-rock-200)); }
  .pcard__title { font-family: var(--font-sans); font-weight: 600; font-size: 1.75rem; color: #3b0800; margin: 1.5rem 0 0; }
  .pcard__tags { list-style: none; padding: 0; margin: 1rem 0 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pcard__tags li { font-family: var(--font-body); font-weight: 500; font-size: 0.875rem; color: #3b0800; padding: 0.35em 0.85em; border: 1px solid var(--color-border); border-radius: 999px; }

  .pgrid__empty { text-align: center; font-family: var(--font-sans); font-size: 1.25rem; color: var(--color-text-muted); margin-top: 2rem; }
  /* Pagination : « HOP HOP HOP » + chevrons + cercles numérotés + flèche crayonnée.
     Page active = cercle contouré (texte foncé) ; autres = cercle plein foncé (texte blanc). */
  .pagination { text-align: center; margin-top: clamp(3rem, 6vw, 5rem); }
  .pagination__more { font-family: var(--font-sans); font-weight: 600; font-size: 1.75rem; letter-spacing: -0.01em; color: #3b0800; margin: 0 0 1.5rem; }
  .pager { position: relative; display: inline-flex; align-items: center; gap: 0.85rem; }
  .pager__nums { list-style: none; padding: 0; margin: 0; display: flex; align-items: center; gap: 0.85rem; }
  .pager__nums :global(button) { display: grid; place-items: center; width: 52px; height: 52px; border-radius: 999px; font-family: var(--font-sans); font-size: 1.25rem; color: #fdf4f3; background: #3b0800; border: 1.5px solid #3b0800; cursor: pointer; transition: background 0.15s ease, color 0.15s ease; }
  .pager__nums :global(button.is-active) { background: transparent; color: #3b0800; }
  .pager__arrow { display: grid; place-items: center; width: 40px; height: 40px; background: none; border: none; color: #3b0800; cursor: pointer; }
  .pager__arrow svg { width: 22px; height: 22px; }
  .pager__arrow:disabled { opacity: 0.3; cursor: default; }
  .pager__squiggle { position: absolute; left: calc(100% + 3.5rem); top: -5.5rem; width: clamp(80px, 7vw, 120px); height: auto; pointer-events: none; }

  /* Bande « Ces clients » : fond crème, titre foncé, pastille sunshine, mur de logos. */
  .autres { background: var(--color-canyon-50); padding-block: clamp(3rem, 7vw, 6rem); text-align: center; }
  .autres__title { margin: 0 auto; max-width: 20ch; font-family: var(--font-sans); font-weight: 600; font-size: clamp(2.25rem, 5vw, 5rem); line-height: 1.1; letter-spacing: -0.03em; color: #3b0800; }
  .autres__title .hl { line-height: 1.25; }
  .autres__logos { display: block; width: 100%; max-width: 1180px; height: auto; margin: clamp(2.5rem, 6vw, 4.5rem) auto 0; }

  @media (max-width: 760px) {
    .pgrid__list { grid-template-columns: 1fr; }
    .pager__squiggle { display: none; }
  }
</style>
