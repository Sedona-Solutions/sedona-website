---
interface Props {
  eyebrow?: string;
  titre: string;
  intro?: string;
}
const { eyebrow, titre, intro } = Astro.props;
---

<header class="page-header">
  <div class="container">
    {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
    <h1 class="page-header__title">{titre}</h1>
    {intro && <p class="page-header__intro">{intro}</p>}
  </div>
</header>

<style>
  .page-header {
    background: var(--color-canyon-50);
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem);
  }
  .page-header__eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .page-header__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #3b0800;
    max-width: 18ch;
  }
  .page-header__intro {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    color: #3b0800;
    max-width: 60ch;
  }
</style>
