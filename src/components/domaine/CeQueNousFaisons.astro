---
const { data } = Astro.props;
const items = data?.items ?? [];
const titre = data?.titre ?? [];
---

<section class="cqnf">
  <div class="container">
    <header class="cqnf__head">
      <div>
        {data?.eyebrow && <p class="cqnf__eyebrow">{data.eyebrow}</p>}
        <h2 class="cqnf__title">
          {
            titre.map((s) =>
              s.br ? <br /> : s.pill ? <mark class="hl hl--cactus">{s.t}</mark> : <span>{s.t}</span>,
            )
          }
        </h2>
      </div>
      {data?.intro && <p class="cqnf__intro">{data.intro}</p>}
      <img class="cqnf__squiggle" src="/deco/cqnf-squiggle.svg" alt="" aria-hidden="true" />
    </header>

    <div class="cqnf__list">
      {
        items.map((it) => (
          <details class="acc">
            <summary class="acc__row">
              <img class="acc__icon" src={`/icons/${it.icone}.svg`} alt="" aria-hidden="true" />
              <span class="acc__label">{it.label}</span>
              <span class="acc__plus" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" stroke="#3b0800" stroke-width="2" stroke-linecap="round" /></svg>
              </span>
            </summary>
            <div class="acc__body"><p>{it.texte}</p></div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cqnf { background: var(--color-canyon-50); padding-block: clamp(3rem, 6vw, 5rem); }
  .cqnf__head { position: relative; display: grid; grid-template-columns: 1fr 320px; align-items: start; gap: var(--space-md); margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .cqnf__squiggle { position: absolute; left: 50%; top: 52%; transform: translateY(-50%); width: clamp(150px, 15vw, 250px); height: auto; pointer-events: none; }
  .cqnf__eyebrow {
    font-family: var(--font-sans); font-weight: 400; font-size: 1rem;
    text-transform: uppercase; letter-spacing: 0.08em; color: #3b0800; margin-bottom: 1rem;
  }
  .cqnf__title {
    margin: 0; font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(2.25rem, 5.5vw, 5rem); line-height: 1.05; letter-spacing: -0.03em; color: #3b0800;
  }
  .cqnf__title .hl { line-height: 1.3; }
  .cqnf__intro { font-family: var(--font-sans); font-weight: 500; font-size: 1.0625rem; line-height: 1.4; color: #3b0800; align-self: end; }

  .cqnf__list { max-width: 1088px; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem; }
  .acc { background: #fff; border: 1px solid var(--color-border); border-radius: 18px; }
  .acc__row { display: flex; align-items: center; gap: 1.25rem; padding: 1.5rem 2rem; cursor: pointer; list-style: none; }
  .acc__row::-webkit-details-marker { display: none; }
  .acc__icon { width: 40px; height: 40px; flex: none; }
  .acc__label { flex: 1; font-family: var(--font-sans); font-weight: 700; font-size: 1.125rem; color: #3b0800; }
  .acc__plus { width: 28px; height: 28px; flex: none; transition: transform 0.2s ease; }
  .acc__plus svg { width: 100%; height: 100%; }
  .acc[open] .acc__plus { transform: rotate(45deg); }
  .acc__body { padding: 0 2rem 1.75rem 5.25rem; }
  .acc__body p { margin: 0; font-family: var(--font-body); font-size: 1.0625rem; line-height: 1.55; color: #3b0800; }

  @media (max-width: 820px) {
    .cqnf__head { grid-template-columns: 1fr; }
    .cqnf__squiggle { display: none; }
    .acc__body { padding-left: 2rem; }
  }
</style>
