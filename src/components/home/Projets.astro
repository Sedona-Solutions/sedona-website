---
const { section, projets = [] } = Astro.props;
---

<section class="projets">
  <div class="container">
    <header class="projets__head">
      <h2 class="projets__title">
        <span>Retour sur</span><br />
        nos plus beaux <mark class="hl hl--sky">projets</mark>
      </h2>
      <img class="projets__arrow" src="/deco/arrow-down.svg" alt="" aria-hidden="true" />
      {section?.intro && <p class="projets__intro">{section.intro}</p>}
    </header>

    <ul class="projets__grid">
      {
        projets.map((p) => (
          <li class="proj">
            <a href={`/projets/${p.slug}`} class="proj__media">
              {p.couverture ? (
                <img src={p.couverture} alt={p.titre} loading="lazy" />
              ) : (
                <span class="proj__placeholder" aria-hidden="true" />
              )}
            </a>
            <h3 class="proj__title">{p.client ?? p.titre}</h3>
            {p.client && <p class="proj__sub">{p.titre}</p>}
            {p.tags?.length > 0 && (
              <ul class="proj__tags">
                {p.tags.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>

    <div class="projets__all">
      <a href="/projets">Voir tous nos projets</a>
    </div>
  </div>
</section>

<style>
  .projets {
    background: var(--color-canyon-50);
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }
  .projets__head {
    position: relative;
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .projets__title {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5.5vw, 5rem); /* 80px */
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #3b0800;
  }
  .projets__arrow {
    position: absolute;
    top: 0;
    right: 8%;
    width: clamp(60px, 9vw, 150px);
    height: auto;
    pointer-events: none;
  }
  .projets__intro {
    margin: 1.5rem auto 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1.5rem; /* 24px */
    color: #3b0800;
  }

  .projets__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 3rem) 2rem;
  }
  .proj__media {
    display: block;
    aspect-ratio: 16 / 11;
    border-radius: 18px;
    overflow: hidden;
    background: var(--color-neutral-100);
  }
  .proj__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .proj__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-canyon-200), var(--color-red-rock-200));
  }
  .proj__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.75rem; /* 28px */
    letter-spacing: -0.01em;
    color: #3b0800;
    margin: 1.25rem 0 0;
  }
  .proj__sub {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.25rem; /* 20px */
    color: #3b0800;
    margin: 0.25rem 0 0;
  }
  .proj__tags {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .proj__tags li {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.875rem; /* 14px */
    color: #3b0800;
    padding: 0.35em 0.85em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  .projets__all {
    text-align: center;
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }
  .projets__all a {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #3b0800;
    text-decoration: underline;
    text-underline-offset: 6px;
  }
  .projets__all a:hover { color: var(--color-primary); }

  @media (max-width: 760px) {
    .projets__grid { grid-template-columns: 1fr; }
    .projets__arrow { display: none; }
  }
</style>
