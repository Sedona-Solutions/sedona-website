---
const colonne1 = [
  { label: "Produits digitaux", href: "/domaines/produits-digitaux" },
  { label: "Data & intelligence artificielle", href: "/domaines/data-ia" },
  { label: "Infra & sécurité", href: "/domaines/infra-securite" },
];
const colonne2 = [
  { label: "Notre histoire", href: "/histoire" },
  { label: "Rejoindre la tribu", href: "/carrieres" },
  { label: "Blog", href: "/blog" },
];
const legal = [
  { label: "Politique RSE", href: "/politique-rse" },
  { label: "Politique de confidentialité", href: "/confidentialite" },
  { label: "Mentions légales", href: "/mentions-legales" },
];
const annee = 2026;

const icones = {
  facebook: `<path d="M13.5 9H11V7.5c0-.7.3-1 1-1h1.5V4h-2C9.5 4 8.5 5.3 8.5 7v2H7v2.5h1.5V20H11v-8.5h1.8L13.5 9z"/>`,
  x: `<path d="M14.2 4h2.3l-5 5.7L17.5 20h-4.3l-3.3-4.4L6 20H3.7l5.4-6.1L4 4h4.4l3 4 3.8-4zm-.8 14.4h1.3L7.3 5.3H6L13.4 18.4z"/>`,
  linkedin: `<path d="M7 9H4.5v9H7V9zM5.7 4.5A1.4 1.4 0 105.7 7.3a1.4 1.4 0 000-2.8zM19.5 13.3c0-2.4-1.3-3.5-3-3.5-1.4 0-2 .8-2.3 1.3V9H11.7c0 .7 0 9 0 9h2.5v-5c0-.3 0-.5.1-.7.2-.5.6-1 1.4-1 1 0 1.4.8 1.4 1.9V18h2.5l-.1-4.7z"/>`,
  youtube: `<path d="M21 8.5s-.2-1.4-.8-2c-.7-.8-1.6-.8-2-.9C15.4 5.4 12 5.4 12 5.4h0s-3.4 0-6.2.2c-.4.1-1.3.1-2 .9-.6.6-.8 2-.8 2S3 10.1 3 11.8v1.1c0 1.6.2 3.3.2 3.3s.2 1.4.8 2c.7.8 1.7.8 2.1.9 1.6.1 6 .2 6 .2s3.4 0 6.2-.2c.4-.1 1.3-.1 2-.9.6-.6.8-2 .8-2s.2-1.6.2-3.3v-1.1c0-1.7-.2-3.3-.2-3.3zM10.2 14.7V9.9l4.3 2.4-4.3 2.4z"/>`,
};
const reseaux = [
  { nom: "Facebook", url: "#", icone: "facebook" },
  { nom: "X", url: "#", icone: "x" },
  { nom: "LinkedIn", url: "https://www.linkedin.com/company/sedona", icone: "linkedin" },
  { nom: "YouTube", url: "#", icone: "youtube" },
];
---

<footer class="ftr">
  <div class="container">
    <div class="ftr__top">
      <nav class="ftr__col" aria-label="Domaines">
        {colonne1.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <nav class="ftr__col" aria-label="Entreprise">
        {colonne2.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <div class="ftr__social">
        <h3>Suivez-nous sur nos réseaux sociaux</h3>
        <p>Pour ne rien manquer de nos actualités et offres exclusives !</p>
        <ul>
          {
            reseaux.map((r) => (
              <li>
                <a href={r.url} aria-label={r.nom}>
                  <svg viewBox="0 0 24 24" fill="#3b0800" set:html={icones[r.icone]} />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="ftr__bottom">
      <p class="ftr__copy">© 1999-{annee} SEDONA ❥ Réalisé avec passion par notre tribu et l'aide de Koko. Tous droits réservés.</p>
      <nav class="ftr__legal" aria-label="Mentions">
        {legal.map((l, i) => (
          <>
            {i > 0 && <span class="ftr__bar" aria-hidden="true">|</span>}
            <a href={l.href}>{l.label}</a>
          </>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .ftr {
    background: #3b0800;
    color: #fdf4f3;
    padding-block: clamp(2.5rem, 5vw, 3.5rem) clamp(1.5rem, 3vw, 2rem);
  }
  .ftr__top {
    display: grid;
    grid-template-columns: 1fr 1fr 1.4fr;
    gap: var(--space-md);
    padding-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }
  .ftr__col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .ftr__col a {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.25rem; /* 20px */
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fdf4f3;
  }
  .ftr__col a:hover { color: var(--color-canyon-300); }

  .ftr__social h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.5rem; /* 24px */
    margin: 0;
  }
  .ftr__social p {
    font-family: var(--font-body);
    font-size: 1rem;
    margin: 0.75rem 0 1.5rem;
    color: color-mix(in srgb, #fdf4f3 85%, transparent);
  }
  .ftr__social ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.75rem;
  }
  .ftr__social a {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: #fcf6f0;
  }
  .ftr__social svg { width: 22px; height: 22px; }

  .ftr__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid color-mix(in srgb, #fdf4f3 14%, transparent);
  }
  .ftr__copy {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: color-mix(in srgb, #fdf4f3 80%, transparent);
    margin: 0;
  }
  .ftr__legal {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .ftr__legal a {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: #fdf4f3;
  }
  .ftr__legal a:hover { color: var(--color-canyon-300); }
  .ftr__bar { color: color-mix(in srgb, #fdf4f3 40%, transparent); }

  @media (max-width: 820px) {
    .ftr__top { grid-template-columns: 1fr 1fr; }
    .ftr__social { grid-column: 1 / -1; }
    .ftr__bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
